# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI API Key (existing)
OPENAI_API_KEY=your_openai_api_key

# Health chatbot
# Auth is required by default because chat/profile data can contain sensitive health information.
# Set to false only for local demos without Supabase persistence.
HEALTH_CHAT_REQUIRE_AUTH=true

# Comma-separated owner/test accounts that should bypass paid feature gates.
NEXT_PUBLIC_FULL_ACCESS_EMAILS=gautammaddyson@gmail.com

# ElevenLabs API Key (existing)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Spotify API (existing)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Stability AI music generation
STABILITY_API_KEY=your_stability_api_key
# Optional: override if Stability changes the preferred audio endpoint.
STABILITY_AUDIO_ENDPOINT=https://api.stability.ai/v2beta/audio/stable-audio-2/text-to-audio
STABILITY_AUDIO_DURATION_SECONDS=30
STABILITY_AUDIO_OUTPUT_FORMAT=mp3

# Optional external artist feature enrichment.
# When unset, Spotify analysis returns metadata only.
MUSIC_FEATURES_API_URL=
MUSIC_FEATURES_API_KEY=

# Health knowledge base uses Supabase pgvector via supabase/schema.sql.

# Stripe (for future payment integration)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PortfolioFlow
